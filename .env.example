# --- QVeris.ai financial data gateway (backend only) ---
QVERIS_API_KEY=your_qveris_api_key_here
QVERIS_BASE_URL=https://qveris.ai/api/v1
QVERIS_SESSION_ID=alphaquantpro-local

# --- DeepSeek LLM runtime (backend only, DeepSeek is the ONLY supported provider) ---
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- Storage ---
DATABASE_URL=sqlite:///./alphaquantpro.db

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
